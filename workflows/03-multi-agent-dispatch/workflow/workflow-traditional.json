    {
      "id": "c3d4e5f6-a7b8-4c9d-0e1f-2a3b4c5d6e7f",
      "name": "Dispatcher Klassifizierung",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        300,
        400
      ],
      "parameters": {
        "promptType": "define",
        "text": "={{ `Klassifiziere diese Support-Anfrage und antworte als reines JSON.\n\nText: ${$json.body.text}\nUser: ${$json.body.user}\nKanal: ${$json.body.channel}\n\nJSON Format:\n{\"category\": \"tech|sales|faq|unknown\", \"urgency\": 1-10, \"summary\": \"kurze Zusammenfassung\"}` }}",
        "messages": {
          "messageValues": [
            {
              "type": "SystemMessagePromptTemplate",
              "message": "Du bist ein Support-Dispatcher. Klassifiziere eingehende Anfragen in: tech (technische Probleme, Server, Fehler, Code), sales (Preise, Angebote, Pakete, Kosten), faq (allgemeine Fragen, Passwort, Account, Anleitungen), unknown (unklar). Bewerte Dringlichkeit 1-10. Antworte NUR als JSON ohne Markdown."
            }
          ]
        }
      }
    },
    {
      "id": "d4e5f6a7-b8c9-4d0e-1f2a-3b4c5d6e7f80",
      "name": "Kategorie parsen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        550,
        400
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const raw = $json.text || $json.response || \"\";\nconst start = raw.indexOf('{');\nconst end = raw.lastIndexOf('}');\nlet category = 'unknown', urgency = 5, summary = '';\nif (start >= 0 && end > start) {\n  try {\n    const parsed = JSON.parse(raw.substring(start, end + 1));\n    category = (parsed.category || 'unknown').toLowerCase();\n    urgency = parseInt(parsed.urgency) || 5;\n    summary = parsed.summary || '';\n  } catch (e) {}\n}\nconst wb = $('Webhook Eingang').item.json;\nreturn { json: { category, urgency, summary, originalText: wb.body.text || '', originalUser: wb.body.user || '', originalChannel: wb.body.channel || '' } };"
      }
    },
    {
      "id": "e5f6a7b8-c9d0-4e1f-2a3b-4c5d6e7f8091",
      "name": "Route Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.4,
      "position": [
        800,
        400
      ],
      "parameters": {
