        "text": "={{ `Bearbeite diese Sales-Anfrage:\n\nAnfrage: ${$json.originalText}\nUser: ${$json.originalUser}\nKanal: ${$json.originalChannel}\nZusammenfassung: ${$json.summary}` }}",
